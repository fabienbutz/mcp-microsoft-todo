{
  "name": "microsoft-todo-mcp",
  "version": "0.2.0",
  "description": "Model Context Protocol server for Microsoft To Do (via Microsoft Graph).",
  "type": "module",
  "license": "MIT",
  "author": "Fabien Butz",
  "homepage": "https://github.com/fabienbutz/microsoft-todo-mcp#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/fabienbutz/microsoft-todo-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/fabienbutz/microsoft-todo-mcp/issues"
  },
  "keywords": [
    "mcp",
